{
  "name": "PortfolioItem",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title of the artwork/photo"
    },
    "description": {
      "type": "string",
      "description": "Description or story behind the piece"
    },
    "image_url": {
      "type": "string",
      "description": "High resolution image URL"
    },
    "category": {
      "type": "string",
      "enum": [
        "photography",
        "pintacaras",
        "paints"
      ],
      "description": "Portfolio category"
    },
    "year": {
      "type": "integer",
      "description": "Year the work was created"
    },
    "dimensions": {
      "type": "string",
      "description": "Physical dimensions if applicable"
    },
    "medium": {
      "type": "string",
      "description": "Medium used (e.g., Digital Photography, Oil on Canvas)"
    },
    "featured": {
      "type": "boolean",
      "default": false,
      "description": "Whether to feature on homepage"
    },
    "sort_order": {
      "type": "integer",
      "default": 0,
      "description": "Display order"
    }
  },
  "required": [
    "title",
    "image_url",
    "category"
  ]
}